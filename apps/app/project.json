{
  "name": "app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/app",
        "browser": "apps/app/src/main.ts",
        "tsConfig": "apps/app/tsconfig.app.json",
        "inlineStyleLanguage": "css",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/app/public"
          }
        ],
        "styles": [
          "apps/app/src/styles.css",
          "libs/ui/theme/src/lib/material.scss"
        ]
      },
      "configurations": {
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/app/src/environments/environment.ts",
              "with": "apps/app/src/environments/environment.development.ts"
            }
          ]
        },
        "preview": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "0.5mb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/app/src/environments/environment.ts",
              "with": "apps/app/src/environments/environment.preview.ts"
            }
          ]
        },
        "live": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1.6mb",
              "maximumError": "1.9mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/app/src/environments/environment.ts",
              "with": "apps/app/src/environments/environment.live.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "configurations": {
        "development": {
          "buildTarget": "app:build:development"
        },
        "preview": {
          "buildTarget": "app:build:preview"
        },
        "live": {
          "buildTarget": "app:build:live"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "app:build",
        "staticFilePath": "dist/apps/app/browser",
        "spa": true
      }
    }
  }
}
